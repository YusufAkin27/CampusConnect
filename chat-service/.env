AUTH_SERVICE_URL=http://localhost:8081
USER_SERVICE_URL=http://localhost:8082
FRIEND_SERVICE_URL=http://localhost:8084
MEDIA_SERVICE_URL=http://localhost:8087
LOGGING_SERVICE_URL=http://localhost:8085

CHAT_DIRECT_ONLY_FRIENDS=false
CHAT_MESSAGE_RATE_LIMIT_PER_SECOND=5
