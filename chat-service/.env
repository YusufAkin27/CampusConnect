NODE_ENV=development
PORT=8095

DATABASE_URL=postgresql://postgres:12345@localhost:5432/campusconnect_chat

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

CONSUL_HOST=localhost
CONSUL_PORT=8500
SERVICE_NAME=chat-service
SERVICE_PORT=8095
