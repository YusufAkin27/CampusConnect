CHAT_MAX_GROUP_MEMBERS=250
CHAT_MAX_MEDIA_PER_MESSAGE=10
CHAT_MAX_MESSAGE_LENGTH=4000
CHAT_MESSAGE_EDIT_WINDOW_MINUTES=15
CHAT_MESSAGE_DELETE_FOR_EVERYONE_WINDOW_MINUTES=30
CHAT_MAX_PINNED_MESSAGES=5

